{
  "name": "@velocity-bpa/n8n-nodes-polymesh",
  "version": "1.0.0",
  "description": "n8n community node for Polymesh - Manages security tokens and their properties on Polymesh",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/velocity-bpa/n8n-nodes-polymesh",
  "author": {
    "name": "Velocity BPA",
    "email": "support@velocitybpa.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velocity-bpa/n8n-nodes-polymesh.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PolymeshApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Polymesh/Polymesh.node.js"
    ]
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "polymesh",
    "blockchain",
    "security-tokens"
  ],
  "scripts": {
    "build": "tsc && gulp copy",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^18.16.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.42.0",
    "eslint-plugin-n8n-nodes-base": "^1.15.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}